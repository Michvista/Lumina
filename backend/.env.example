# Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/lumina_db"

# ── Google Gemini ────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq ─────────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://console.cloudinary.com/ → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── YarnGPT ──────────────────────────────────────────────────────────────────
# Get from: https://yarngpt.ai → Sign in → API key
YARNGPT_API_KEY=your_yarngpt_api_key_here
# Optional: change default voice. Options: Idera, Emma, Zainab, Osagie, Wura,
# Jude, Chinenye, Tayo, Regina, Femi, Adaora, Umar, Mary, Nonso, Remi, Adam
YARNGPT_DEFAULT_VOICE=Idera

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS). In production, set to your Vercel deployment URL.
FRONTEND_URL=http://localhost:5173
